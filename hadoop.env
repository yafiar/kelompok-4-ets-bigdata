# Hadoop Environment Variables
# Digunakan oleh kontainer namenode dan datanode untuk konfigurasi cluster.

# Menentukan Namenode sebagai default file system
CORE_CONF_fs_defaultFS=hdfs://namenode:9000

# Nama cluster
CLUSTER_NAME=pangan-cluster

# Konfigurasi replikasi (berapa kali data diduplikat). 
# Karena kita hanya pakai 1 datanode, set ke 1.
HDFS_CONF_dfs_replication=1

# Port untuk datanode
HDFS_CONF_dfs_datanode_data_dir=file:///hadoop/dfs/data
HDFS_CONF_dfs_namenode_name_dir=file:///hadoop/dfs/name
